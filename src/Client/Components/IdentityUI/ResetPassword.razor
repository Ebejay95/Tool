@page "/reset-password"
@using Microsoft.AspNetCore.WebUtilities
@inject IAuthService AuthService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>Passwort zurücksetzen - CMC</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Style="margin-top: 64px;">
    <MudPaper Elevation="2" Style="padding: 32px;">
        <div style="text-align: center; margin-bottom: 32px;">
            <MudIcon Icon="Icons.Material.Filled.VpnKey" Size="Size.Large" Color="Color.Primary" />
            <MudText Typo="Typo.h4" GutterBottom="true" Style="margin-top: 16px;">
                Neues Passwort festlegen
            </MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Geben Sie Ihr neues Passwort ein.
            </MudText>
        </div>

        @if (string.IsNullOrEmpty(_token))
        {
            <MudAlert Severity="Severity.Error">
                <strong>Ungültiger Link!</strong> Der Reset-Link ist ungültig oder abgelaufen.
            </MudAlert>

            <div style="text-align: center; margin-top: 24px;">
                <MudButton Href="/forgot-password"
                           Variant="Variant.Filled"
                           Color="Color.Primary">
                    Neuen Reset-Link anfordern
                </MudButton>
            </div>
        }
        else if (!_passwordReset)
        {
            <EditForm Model="@_model" OnValidSubmit="@HandleResetPassword">
                <DataAnnotationsValidator />

                <MudTextField @bind-Value="_model.NewPassword"
                              Label="Neues Passwort"
                              Variant="Variant.Outlined"
                              InputType="@_pwInputType"
                              Adornment="Adornment.End"
                              AdornmentIcon="@_pwIcon"
                              OnAdornmentClick="TogglePw"
                              FullWidth="true"
                              Margin="Margin.Dense"
                              Class="mb-4"
                              HelperText="Mindestens 8 Zeichen"
                              For="@(() => _model.NewPassword)" />

                <MudTextField @bind-Value="_model.ConfirmPassword"
                              Label="Passwort bestätigen"
                              Variant="Variant.Outlined"
                              InputType="@_confirmPwInputType"
                              Adornment="Adornment.End"
                              AdornmentIcon="@_confirmPwIcon"
                              OnAdornmentClick="ToggleConfirmPw"
                              FullWidth="true"
                              Margin="Margin.Dense"
                              Class="mb-4"
                              Error="@(_model.ConfirmPassword != _model.NewPassword && !string.IsNullOrEmpty(_model.ConfirmPassword))"
                              ErrorText="Passwörter stimmen nicht überein"
                              For="@(() => _model.ConfirmPassword)" />

                <MudButton ButtonType="ButtonType.Submit"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           Size="Size.Large"
                           FullWidth="true"
                           Class="mb-4"
                           Disabled="@(_isLoading || _model.ConfirmPassword != _model.NewPassword || string.IsNullOrEmpty(_model.NewPassword))">
                    @if (_isLoading)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                        <span style="margin-left: 8px;">Wird gespeichert...</span>
                    }
                    else
                    {
                        <span>Passwort zurücksetzen</span>
                    }
                </MudButton>

            </EditForm>
        }
        else
        {
            <div style="text-align: center;">
                <MudIcon Icon="Icons.Material.Filled.CheckCircle" Size="Size.Large" Color="Color.Success" />
                <MudText Typo="Typo.h6" Color="Color.Success" Style="margin: 16px 0;">
                    Passwort erfolgreich zurückgesetzt!
                </MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Style="margin-bottom: 24px;">
                    Sie können sich nun mit Ihrem neuen Passwort anmelden.
                </MudText>

                <MudButton Href="/login"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           Size="Size.Large">
                    Zur Anmeldung
                </MudButton>
            </div>
        }

        @if (!string.IsNullOrEmpty(_token) && !_passwordReset)
        {
            <MudDivider Style="margin: 24px 0;" />

            <div style="text-align: center;">
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Doch nicht zurücksetzen?
                    <MudLink Href="/login" Color="Color.Primary">
                        Zurück zur Anmeldung
                    </MudLink>
                </MudText>
            </div>
        }
    </MudPaper>
</MudContainer>

@code {
    private readonly ResetPasswordModel _model = new();
    private bool _isLoading = false;
    private bool _passwordReset = false;
    private string _token = string.Empty;

    private bool _showPw = false;
    private InputType _pwInputType = InputType.Password;
    private string _pwIcon = Icons.Material.Filled.VisibilityOff;
    private void TogglePw()
    {
        _showPw = !_showPw;
        _pwInputType = _showPw ? InputType.Text : InputType.Password;
        _pwIcon = _showPw ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff;
    }

    private bool _showConfirmPw = false;
    private InputType _confirmPwInputType = InputType.Password;
    private string _confirmPwIcon = Icons.Material.Filled.VisibilityOff;
    private void ToggleConfirmPw()
    {
        _showConfirmPw = !_showConfirmPw;
        _confirmPwInputType = _showConfirmPw ? InputType.Text : InputType.Password;
        _confirmPwIcon = _showConfirmPw ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff;
    }

    protected override void OnInitialized()
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);

        if (query.TryGetValue("token", out var tokenValue))
        {
            _token = tokenValue.ToString();
        }
    }

    private async Task HandleResetPassword()
    {
        if (_model.NewPassword != _model.ConfirmPassword)
        {
            Snackbar.Add("Passwörter stimmen nicht überein", Severity.Error);
            return;
        }

        if (_model.NewPassword.Length < 8)
        {
            Snackbar.Add("Passwort muss mindestens 8 Zeichen lang sein", Severity.Error);
            return;
        }

        try
        {
            _isLoading = true;
            var result = await AuthService.ResetPasswordAsync(_token, _model.NewPassword);

            if (result.IsSuccess)
            {
                _passwordReset = true;
                Snackbar.Add("Passwort erfolgreich zurückgesetzt!", Severity.Success);
            }
            else
            {
                Snackbar.Add($"Fehler beim Zurücksetzen: {result.Error}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Ein Fehler ist aufgetreten: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    public class ResetPasswordModel
    {
        public string NewPassword     { get; set; } = string.Empty;
        public string ConfirmPassword { get; set; } = string.Empty;
    }
}
