@page "/forgot-password"
@inject IAuthService AuthService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>Passwort zurücksetzen - CMC</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Style="margin-top: 64px;">
    <MudPaper Elevation="2" Style="padding: 32px;">
        <div style="text-align: center; margin-bottom: 32px;">
            <MudIcon Icon="Icons.Material.Filled.Lock" Size="Size.Large" Color="Color.Primary" />
            <MudText Typo="Typo.h4" GutterBottom="true" Style="margin-top: 16px;">
                Passwort vergessen?
            </MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Geben Sie Ihre E-Mail-Adresse ein und wir senden Ihnen einen Link zum Zurücksetzen.
            </MudText>
        </div>

        @if (!_emailSent)
        {
            <EditForm Model="@_model" OnValidSubmit="@RequestPasswordReset">
                <DataAnnotationsValidator />

                <MudTextField @bind-Value="_model.Email"
                              Label="E-Mail-Adresse"
                              Variant="Variant.Outlined"
                              InputType="InputType.Email"
                              FullWidth="true"
                              Margin="Margin.Dense"
                              Class="mb-4"
                              For="@(() => _model.Email)" />

                <MudButton ButtonType="ButtonType.Submit"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           Size="Size.Large"
                           FullWidth="true"
                           Class="mb-4"
                           Disabled="@_isLoading">
                    @if (_isLoading)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                        <span style="margin-left: 8px;">Wird gesendet...</span>
                    }
                    else
                    {
                        <span>Reset-Link senden</span>
                    }
                </MudButton>

            </EditForm>
        }
        else
        {
            <div style="text-align: center;">
                <MudIcon Icon="Icons.Material.Filled.CheckCircle" Size="Size.Large" Color="Color.Success" />
                <MudText Typo="Typo.h6" Color="Color.Success" Style="margin: 16px 0;">
                    E-Mail gesendet!
                </MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Style="margin-bottom: 24px;">
                    Wir haben einen Link zum Zurücksetzen an <strong>@_model.Email</strong> gesendet.
                    Überprüfen Sie Ihr Postfach und folgen Sie den Anweisungen.
                </MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary" Style="margin-bottom: 24px;">
                    Der Link ist 1 Stunde gültig.
                </MudText>
            </div>
        }

        <MudDivider Style="margin: 24px 0;" />

        <div style="text-align: center;">
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Erinnern Sie sich an Ihr Passwort?
                <MudLink Href="/login" Color="Color.Primary">
                    Zurück zur Anmeldung
                </MudLink>
            </MudText>
        </div>
    </MudPaper>
</MudContainer>

@code {
    private readonly ForgotPasswordModel _model = new();
    private bool _isLoading = false;
    private bool _emailSent = false;

    private async Task RequestPasswordReset()
    {
        try
        {
            _isLoading = true;
            var result = await AuthService.RequestPasswordResetAsync(_model.Email);

            if (result.IsSuccess)
            {
                _emailSent = true;
                Snackbar.Add("Reset-Link wurde erfolgreich gesendet!", Severity.Success);
            }
            else
            {
                Snackbar.Add($"Fehler beim Senden: {result.Error}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Ein Fehler ist aufgetreten: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    public class ForgotPasswordModel
    {
        public string Email { get; set; } = string.Empty;
    }
}
