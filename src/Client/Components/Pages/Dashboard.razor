@page "/dashboard"
@page "/todos"
@using App.Components.TodosUI
@inject IAuthService AuthService
@inject TodoApiService TodoApiService
@inject TaxonomyApiService TaxonomyApiService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PageTitle>Dashboard - CMC</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large">
    <MudGrid>
        <MudItem xs="12">
            <TodoCreateForm Model="@_newTodo"
                            OnSubmit="@HandleCreateAsync"
                            Loading="@_isCreating"
                            AvailableCategories="@_categories"
                            AvailableTags="@_tags"
                            OnCreateCategoryRequested="@HandleCreateCategoryAsync"
                            OnCreateTagRequested="@HandleCreateTagAsync" />
        </MudItem>

        <MudItem xs="12">
            <TodoDataTable Items="@_todos"
                           Loading="@_isLoadingTodos"
                           OnToggleStatus="@HandleToggleStatusAsync"
                           OnEdit="@HandleOpenEditDialog"
                           OnDelete="@HandleDeleteAsync"
                           OnRefresh="@LoadTodosAsync"
                           AvailableCategories="@_categories"
                           AvailableTags="@_tags" />
        </MudItem>
    </MudGrid>
</MudContainer>

<!-- ── Aufgabe bearbeiten Dialog ───────────────────────────────────────── -->
<EntityDialog Title="Aufgabe bearbeiten"
              TitleIcon="@Icons.Material.Filled.Edit"
              IsVisible="@_editDialogOpen"
              IsVisibleChanged="@(v => { if (!v) CloseEditDialog(); })"
              OnSave="@HandleSaveEditAsync"
              OnCancel="@CloseEditDialog"
              IsSaving="@_isSavingEdit">
    <FormContent>
        <TodoCreateForm Model="@_editTodoModel"
                        OnSubmit="@HandleSaveEditAsync"
                        Loading="@_isSavingEdit"
                        ShowSubmitButton="false"
                        ShowTitle="false"
                        ShowPaper="false"
                        AvailableCategories="@_categories"
                        AvailableTags="@_tags"
                        OnCreateCategoryRequested="@HandleCreateCategoryAsync"
                        OnCreateTagRequested="@HandleCreateTagAsync" />
    </FormContent>
</EntityDialog>

@code {
    private List<TodoListItemViewModel> _todos          = [];
    private CreateTodoViewModel         _newTodo        = new();
    private bool                        _isLoadingTodos = false;
    private bool                        _isCreating     = false;
    private List<CategoryViewModel>     _categories     = [];
    private List<TagViewModel>          _tags           = [];

    // ── Edit-Dialog State ───────────────────────────────────────────────────
    private bool                    _editDialogOpen = false;
    private bool                    _isSavingEdit   = false;
    private TodoListItemViewModel?  _editingTodo    = null;
    private CreateTodoViewModel     _editTodoModel  = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var isAuth = await AuthService.IsAuthenticatedAsync();
        if (!isAuth) { Navigation.NavigateTo("/login"); return; }

        // Master darf das Dashboard nicht sehen
        var role = await AuthService.GetCurrentRoleAsync();
        if (role == "master") { Navigation.NavigateTo("/master/users", replace: true); return; }

        await AuthService.InitializeAsync();
        await Task.WhenAll(LoadTodosAsync(), LoadTaxonomyAsync());
        StateHasChanged();
    }

    private async Task LoadTaxonomyAsync()
    {
        var catResult = await TaxonomyApiService.GetCategoriesAsync();
        var tagResult = await TaxonomyApiService.GetTagsAsync();
        _categories = catResult.IsSuccess ? catResult.Value.ToViewModels() : [];
        _tags       = tagResult.IsSuccess ? tagResult.Value.ToViewModels() : [];
    }

    private async Task LoadTodosAsync()
    {
        _isLoadingTodos = true;
        StateHasChanged();

        var result = await TodoApiService.GetUserTodosAsync();
        _todos = result.IsSuccess
            ? result.Value.ToViewModels()
            : [];

        if (!result.IsSuccess)
            Snackbar.Add($"Fehler beim Laden der Aufgaben: {result.Error}", Severity.Error);

        _isLoadingTodos = false;
        StateHasChanged();
    }

    private async Task HandleCreateAsync()
    {
        _isCreating = true;
        var result = await TodoApiService.CreateTodoAsync(_newTodo.ToDto());

        if (result.IsSuccess)
        {
            Snackbar.Add("Aufgabe erfolgreich erstellt!", Severity.Success);
            _newTodo = new CreateTodoViewModel();
            await LoadTodosAsync();
        }
        else
        {
            Snackbar.Add($"Fehler beim Erstellen: {result.Error}", Severity.Error);
        }

        _isCreating = false;
    }

    private async Task HandleToggleStatusAsync(TodoListItemViewModel todo)
    {
        var newStatus = todo.IsCompleted ? TodoStatus.Pending : TodoStatus.Completed;
        var result    = await TodoApiService.UpdateTodoStatusAsync(todo.Id.ToString(), newStatus);

        if (result.IsSuccess)
        {
            await LoadTodosAsync();
            Snackbar.Add("Status aktualisiert!", Severity.Success);
        }
        else
            Snackbar.Add($"Fehler: {result.Error}", Severity.Error);
    }

    private async Task HandleDeleteAsync(Guid id)
    {
        var result = await TodoApiService.DeleteTodoAsync(id.ToString());

        if (result.IsSuccess)
        {
            await LoadTodosAsync();
            Snackbar.Add("Aufgabe gelöscht!", Severity.Success);
        }
        else
            Snackbar.Add($"Fehler: {result.Error}", Severity.Error);
    }

    // ── Edit-Dialog Handler ─────────────────────────────────────────────────

    private void HandleOpenEditDialog(TodoListItemViewModel todo)
    {
        _editingTodo   = todo;
        _editTodoModel = todo.ToEditModel();
        _editDialogOpen = true;
    }

    private void CloseEditDialog()
    {
        _editDialogOpen = false;
        _editingTodo    = null;
    }

    private async Task HandleSaveEditAsync()
    {
        if (_editingTodo is null) return;

        _isSavingEdit = true;

        var dto    = _editTodoModel.ToUpdateDto();
        var result = await TodoApiService.UpdateTodoAsync(_editingTodo.Id.ToString(), dto);

        if (result.IsSuccess)
        {
            Snackbar.Add("Aufgabe aktualisiert!", Severity.Success);
            CloseEditDialog();
            await LoadTodosAsync();
        }
        else
        {
            Snackbar.Add($"Fehler beim Speichern: {result.Error}", Severity.Error);
        }

        _isSavingEdit = false;
    }

    private async Task HandleCreateCategoryAsync(string label)
    {
        var result = await TaxonomyApiService.CreateCategoryAsync(label);
        if (result.IsSuccess)
        {
            var vm = result.Value.ToViewModel();
            _categories.Add(vm);
            _newTodo.SelectedCategoryIds.Add(vm.Id);
            StateHasChanged();
        }
        else
            Snackbar.Add($"Kategorie konnte nicht erstellt werden: {result.Error}", Severity.Error);
    }

    private async Task HandleCreateTagAsync(string label)
    {
        var result = await TaxonomyApiService.CreateTagAsync(label);
        if (result.IsSuccess)
        {
            var vm = result.Value.ToViewModel();
            _tags.Add(vm);
            _newTodo.SelectedTagIds.Add(vm.Id);
            StateHasChanged();
        }
        else
            Snackbar.Add($"Tag konnte nicht erstellt werden: {result.Error}", Severity.Error);
    }
}
