@page "/measures"
@using App.Components.MeasuresUI
@inject IAuthService AuthService
@inject MeasureApiService MeasureApiService
@inject TaxonomyApiService TaxonomyApiService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PageTitle>Maßnahmen - CMC</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large">
    <MudGrid>
        <MudItem xs="12">
            <MeasureCreateForm Model="@_newMeasure"
                               OnSubmit="@HandleCreateAsync"
                               Loading="@_isCreating"
                               AvailableCategories="@_categories"
                               AvailableTags="@_tags"
                               OnCreateCategoryRequested="@HandleCreateCategoryAsync"
                               OnCreateTagRequested="@HandleCreateTagAsync" />
        </MudItem>

        <MudItem xs="12">
            <MeasureDataTable Items="@_measures"
                              Loading="@_isLoading"
                              OnEdit="@HandleOpenEditDialog"
                              OnDelete="@HandleDeleteAsync"
                              OnRefresh="@LoadMeasuresAsync"
                              AvailableCategories="@_categories"
                              AvailableTags="@_tags" />
        </MudItem>
    </MudGrid>
</MudContainer>

<!-- ── Maßnahme bearbeiten Dialog ─────────────────────────────────────── -->
<EntityDialog Title="Maßnahme bearbeiten"
              TitleIcon="@Icons.Material.Filled.Edit"
              IsVisible="@_editDialogOpen"
              IsVisibleChanged="@(v => { if (!v) CloseEditDialog(); })"
              OnSave="@HandleSaveEditAsync"
              OnCancel="@CloseEditDialog"
              IsSaving="@_isSavingEdit"
              MaxWidth="MaxWidth.Large">
    <FormContent>
        <MeasureCreateForm Model="@_editMeasureModel"
                           OnSubmit="@HandleSaveEditAsync"
                           Loading="@_isSavingEdit"
                           ShowSubmitButton="false"
                           ShowTitle="false"
                           ShowPaper="false"
                           AvailableCategories="@_categories"
                           AvailableTags="@_tags"
                           OnCreateCategoryRequested="@HandleCreateCategoryAsync"
                           OnCreateTagRequested="@HandleCreateTagAsync" />
    </FormContent>
</EntityDialog>

@code {
    private List<MeasureListItemViewModel> _measures   = [];
    private CreateMeasureViewModel         _newMeasure = new();
    private bool                           _isLoading  = false;
    private bool                           _isCreating = false;
    private List<CategoryViewModel>        _categories = [];
    private List<TagViewModel>             _tags       = [];

    // ── Edit-Dialog State ─────────────────────────────────────────────────
    private bool                   _editDialogOpen   = false;
    private bool                   _isSavingEdit     = false;
    private Guid                   _editingMeasureId;
    private MeasureEditState?      _editState        = null;
    private CreateMeasureViewModel _editMeasureModel = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var isAuth = await AuthService.IsAuthenticatedAsync();
        if (!isAuth) { Navigation.NavigateTo("/login"); return; }

        await Task.WhenAll(LoadMeasuresAsync(), LoadTaxonomyAsync());
        StateHasChanged();
    }

    private async Task LoadTaxonomyAsync()
    {
        var catResult = await TaxonomyApiService.GetCategoriesAsync();
        var tagResult = await TaxonomyApiService.GetTagsAsync();
        _categories = catResult.IsSuccess ? catResult.Value.ToViewModels() : [];
        _tags       = tagResult.IsSuccess ? tagResult.Value.ToViewModels() : [];
    }

    private async Task LoadMeasuresAsync()
    {
        _isLoading = true;
        StateHasChanged();

        var result = await MeasureApiService.GetMeasuresAsync();
        _measures = result.IsSuccess
            ? result.Value.ToViewModels()
            : [];

        if (!result.IsSuccess)
            Snackbar.Add($"Fehler beim Laden der Maßnahmen: {result.Error}", Severity.Error);

        _isLoading = false;
        StateHasChanged();
    }

    private async Task HandleCreateAsync()
    {
        _isCreating = true;

        var result = await MeasureApiService.CreateMeasureAsync(_newMeasure.ToDto());

        if (result.IsSuccess)
        {
            Snackbar.Add("Maßnahme erfolgreich erstellt!", Severity.Success);
            _newMeasure = new CreateMeasureViewModel();
            await LoadMeasuresAsync();
        }
        else
        {
            Snackbar.Add($"Fehler beim Erstellen: {result.Error}", Severity.Error);
        }

        _isCreating = false;
    }

    private async Task HandleDeleteAsync(Guid id)
    {
        var result = await MeasureApiService.DeleteMeasureAsync(id);

        if (result.IsSuccess)
        {
            Snackbar.Add("Maßnahme gelöscht.", Severity.Success);
            await LoadMeasuresAsync();
        }
        else
        {
            Snackbar.Add($"Fehler beim Löschen: {result.Error}", Severity.Error);
        }
    }

    // ── Edit-Dialog Handler ─────────────────────────────────────────────────

    private async Task HandleOpenEditDialog(MeasureListItemViewModel item)
    {
        // Vollständiges DTO laden, da MeasureListItemViewModel (Summary) Felder wie
        // EffortHours und Justification nicht enthält.
        _isSavingEdit = true;
        StateHasChanged();

        var result = await MeasureApiService.GetMeasureByIdAsync(item.Id);

        _isSavingEdit = false;

        if (!result.IsSuccess)
        {
            Snackbar.Add($"Maßnahme konnte nicht geladen werden: {result.Error}", Severity.Error);
            return;
        }

        _editingMeasureId = item.Id;
        _editState        = result.Value.ToEditState();
        _editMeasureModel = result.Value.ToEditModel();
        _editDialogOpen   = true;
        StateHasChanged();
    }

    private void CloseEditDialog()
    {
        _editDialogOpen = false;
        _editState      = null;
    }

    private async Task HandleSaveEditAsync()
    {
        if (_editState is null) return;

        _isSavingEdit = true;

        var dto    = _editMeasureModel.ToUpdateDto(_editState);
        var result = await MeasureApiService.UpdateMeasureAsync(_editingMeasureId, dto);

        if (result.IsSuccess)
        {
            Snackbar.Add("Maßnahme aktualisiert!", Severity.Success);
            CloseEditDialog();
            await LoadMeasuresAsync();
        }
        else
        {
            Snackbar.Add($"Fehler beim Speichern: {result.Error}", Severity.Error);
        }

        _isSavingEdit = false;
    }

    private async Task HandleCreateCategoryAsync(string label)
    {
        var result = await TaxonomyApiService.CreateCategoryAsync(label);
        if (result.IsSuccess)
        {
            var vm = result.Value.ToViewModel();
            _categories.Add(vm);
            _newMeasure.SelectedCategoryIds.Add(vm.Id);
            StateHasChanged();
        }
        else
            Snackbar.Add($"Kategorie konnte nicht erstellt werden: {result.Error}", Severity.Error);
    }

    private async Task HandleCreateTagAsync(string label)
    {
        var result = await TaxonomyApiService.CreateTagAsync(label);
        if (result.IsSuccess)
        {
            var vm = result.Value.ToViewModel();
            _tags.Add(vm);
            _newMeasure.SelectedTagIds.Add(vm.Id);
            StateHasChanged();
        }
        else
            Snackbar.Add($"Tag konnte nicht erstellt werden: {result.Error}", Severity.Error);
    }
}
