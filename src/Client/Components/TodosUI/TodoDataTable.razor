@using MudBlazor
@* Tabellen-Ansicht aller Aufgaben.
   Komplett zustandslos – Daten und Callbacks kommen als Parameter. *@

<EntityTable TItem="TodoListItemViewModel"
             Items="@Items"
             Loading="@Loading"
             Title="Meine Aufgaben"
             LoadingText="Lade Aufgaben..."
             EmptyIcon="@Icons.Material.Filled.Assignment"
             EmptyTitle="Keine Aufgaben vorhanden"
             EmptySubText="Erstellen Sie Ihre erste Aufgabe mit dem Formular oben."
             OnRefresh="@OnRefresh">
    <TableContent>
        <MudDataGrid Items="@Items" Filterable="true" SortMode="SortMode.Single">
            <Columns>
                <PropertyColumn Property="x => x.Title" Title="Titel" />

                <PropertyColumn Property="x => x.Status" Title="Status">
                    <CellTemplate>
                        <MudChip Color="@GetStatusColor(context.Item.Status)"
                                 Size="Size.Small"
                                 T="string">
                            @context.Item.StatusLabel
                        </MudChip>
                    </CellTemplate>
                </PropertyColumn>

                <PropertyColumn Property="x => x.Priority" Title="Priorität">
                    <CellTemplate>
                        <MudChip Color="@GetPriorityColor(context.Item.Priority)"
                                 Size="Size.Small"
                                 T="string">
                            @context.Item.PriorityLabel
                        </MudChip>
                    </CellTemplate>
                </PropertyColumn>

                <PropertyColumn Property="x => x.CreatedAt" Title="Erstellt" Format="dd.MM.yyyy HH:mm" />

                <TemplateColumn Title="Taxonomie" Sortable="false">
                    <CellTemplate>
                        <div style="display:flex;flex-wrap:wrap;gap:4px;">
                            @foreach (var id in context.Item.CategoryIds)
                            {
                                var cat = AvailableCategories?.FirstOrDefault(c => c.Id == id);
                                if (cat is not null)
                                {
                                    <div style="padding:2px 8px;border-radius:12px;background:@cat.Color;color:#fff;font-size:0.75rem;">@cat.Label</div>
                                }
                            }
                            @foreach (var id in context.Item.TagIds)
                            {
                                var tag = AvailableTags?.FirstOrDefault(t => t.Id == id);
                                if (tag is not null)
                                {
                                    <div style="padding:2px 8px;border-radius:12px;background:@tag.Color;color:#fff;font-size:0.75rem;">@tag.Label</div>
                                }
                            }
                        </div>
                    </CellTemplate>
                </TemplateColumn>

                <TemplateColumn Title="Aktionen" Sortable="false">
                    <CellTemplate>
                        <MudButton Size="Size.Small"
                                   Color="Color.Primary"
                                   Variant="Variant.Text"
                                   OnClick="@(() => OnToggleStatus.InvokeAsync(context.Item))">
                            @(context.Item.IsCompleted ? "Wiedereröffnen" : "Abschließen")
                        </MudButton>
                        @if (OnEdit.HasDelegate)
                        {
                            <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                           Size="Size.Small"
                                           Color="Color.Default"
                                           Title="Bearbeiten"
                                           OnClick="@(() => OnEdit.InvokeAsync(context.Item))" />
                        }
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Size="Size.Small"
                                       Color="Color.Error"
                                       Title="Löschen"
                                       OnClick="@(() => OnDelete.InvokeAsync(context.Item.Id))" />
                    </CellTemplate>
                </TemplateColumn>
            </Columns>
        </MudDataGrid>
    </TableContent>
</EntityTable>

@code {
    [Parameter, EditorRequired]
    public IReadOnlyList<TodoListItemViewModel> Items { get; set; } = [];

    [Parameter]
    public bool Loading { get; set; }

    /// <summary>Aufgerufen wenn der User "Abschließen/Wiedereröffnen" klickt.</summary>
    [Parameter, EditorRequired]
    public EventCallback<TodoListItemViewModel> OnToggleStatus { get; set; }

    /// <summary>Aufgerufen wenn der User das Bearbeiten-Icon klickt – optional.</summary>
    [Parameter]
    public EventCallback<TodoListItemViewModel> OnEdit { get; set; }

    /// <summary>Aufgerufen wenn der User das Löschen-Icon klickt – übergibt die Id.</summary>
    [Parameter, EditorRequired]
    public EventCallback<Guid> OnDelete { get; set; }

    /// <summary>Aufgerufen beim Klick auf "Aktualisieren".</summary>
    [Parameter, EditorRequired]
    public EventCallback OnRefresh { get; set; }

    [Parameter] public IReadOnlyList<CategoryViewModel>? AvailableCategories { get; set; }
    [Parameter] public IReadOnlyList<TagViewModel>?      AvailableTags       { get; set; }

    private static Color GetStatusColor(TodoStatus status) => status switch
    {
        TodoStatus.Pending    => Color.Warning,
        TodoStatus.InProgress => Color.Info,
        TodoStatus.Completed  => Color.Success,
        TodoStatus.Cancelled  => Color.Error,
        _                                                => Color.Default
    };

    private static Color GetPriorityColor(TodoPriority priority) => priority switch
    {
        TodoPriority.Low      => Color.Default,
        TodoPriority.Medium   => Color.Info,
        TodoPriority.High     => Color.Warning,
        TodoPriority.Critical => Color.Error,
        _                                                => Color.Default
    };
}
