@* Formular zum Erstellen/Bearbeiten einer Aufgabe.
   Komplett zustandslos – alle Daten kommen als Parameter rein.
   ShowPaper=false / ShowTitle=false / ShowSubmitButton=false für Dialog-Modus. *@

<MudPaper Elevation="@(ShowPaper ? 2 : 0)"
          Style="@(ShowPaper ? "padding: 24px;" : "padding: 0; background: transparent; box-shadow: none;")">
    @if (ShowTitle)
    {
        <MudText Typo="Typo.h6" GutterBottom="true">Neue Aufgabe erstellen</MudText>
    }

    <EditForm Model="@Model" OnValidSubmit="@HandleSubmit">
        <DataAnnotationsValidator />
        <DataAnnotationsValidator />

        <MudGrid>
            <MudItem xs="12" md="8">
                <MudTextField @bind-Value="Model.Title"
                              Label="Aufgaben-Titel"
                              Variant="Variant.Outlined"
                              FullWidth="true"
                              Margin="Margin.Dense"
                              Placeholder="z.B. Projekt dokumentieren..."
                              For="@(() => Model.Title)" />
            </MudItem>

            <MudItem xs="12" md="2">
                <MudSelect @bind-Value="Model.Priority"
                           Label="Priorität"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense">
                    <MudSelectItem Value="@TodoPriority.Low">Niedrig</MudSelectItem>
                    <MudSelectItem Value="@TodoPriority.Medium">Mittel</MudSelectItem>
                    <MudSelectItem Value="@TodoPriority.High">Hoch</MudSelectItem>
                    <MudSelectItem Value="@TodoPriority.Critical">Kritisch</MudSelectItem>
                </MudSelect>
            </MudItem>

            @if (ShowSubmitButton)
            {
            <MudItem xs="12" md="2">
                <MudButton ButtonType="ButtonType.Submit"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           Size="Size.Large"
                           FullWidth="true"
                           Disabled="@(Loading || string.IsNullOrWhiteSpace(Model.Title))">
                    @if (Loading)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    }
                    Erstellen
                </MudButton>
            </MudItem>
            }
        </MudGrid>

        <MudTextField @bind-Value="Model.Description"
                      Label="Beschreibung (optional)"
                      Variant="Variant.Outlined"
                      Lines="2"
                      FullWidth="true"
                      Margin="Margin.Dense"
                      Class="mt-3"
                      For="@(() => Model.Description)" />

        <MudGrid Class="mt-3">
            <MudItem xs="12" md="6">
                <TaxonomyPicker TItem="CategoryViewModel"
                                Label="Kategorien"
                                AvailableItems="@AvailableCategories"
                                SelectedIds="@Model.SelectedCategoryIds"
                                SelectedIdsChanged="@StateHasChanged"
                                OnCreateRequested="@OnCreateCategoryRequested"
                                GetId="@(x => x.Id)"
                                GetLabel="@(x => x.Label)"
                                GetColor="@(x => x.Color)" />
            </MudItem>
            <MudItem xs="12" md="6">
                <TaxonomyPicker TItem="TagViewModel"
                                Label="Tags"
                                AvailableItems="@AvailableTags"
                                SelectedIds="@Model.SelectedTagIds"
                                SelectedIdsChanged="@StateHasChanged"
                                OnCreateRequested="@OnCreateTagRequested"
                                GetId="@(x => x.Id)"
                                GetLabel="@(x => x.Label)"
                                GetColor="@(x => x.Color)" />
            </MudItem>
        </MudGrid>
    </EditForm>
</MudPaper>

@code {
    [Parameter, EditorRequired] public CreateTodoViewModel               Model                      { get; set; } = default!;
    [Parameter, EditorRequired] public EventCallback                     OnSubmit                   { get; set; }
    [Parameter]                 public bool                              Loading                    { get; set; }
    [Parameter]                 public IReadOnlyList<CategoryViewModel>? AvailableCategories        { get; set; }
    [Parameter]                 public IReadOnlyList<TagViewModel>?      AvailableTags              { get; set; }
    [Parameter]                 public EventCallback<string>             OnCreateCategoryRequested  { get; set; }
    [Parameter]                 public EventCallback<string>             OnCreateTagRequested       { get; set; }

    /// <summary>Blendet den "Erstellen"-Button aus — z.B. wenn das Formular in einem EntityDialog verwendet wird.</summary>
    [Parameter]                 public bool                              ShowSubmitButton           { get; set; } = true;
    /// <summary>Blendet die Überschrift "Neue Aufgabe erstellen" aus.</summary>
    [Parameter]                 public bool                              ShowTitle                  { get; set; } = true;
    /// <summary>Blendet das umgebende MudPaper aus — z.B. im Dialog-Modus.</summary>
    [Parameter]                 public bool                              ShowPaper                  { get; set; } = true;

    private async Task HandleSubmit() => await OnSubmit.InvokeAsync();
}
