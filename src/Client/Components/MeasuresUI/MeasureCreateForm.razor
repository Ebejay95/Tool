@* Formular zum Erstellen/Bearbeiten einer Maßnahme.
   Komplett zustandslos – alle Daten kommen als Parameter rein.
   ShowPaper=false / ShowTitle=false / ShowSubmitButton=false für Dialog-Modus. *@

<MudPaper Elevation="@(ShowPaper ? 2 : 0)"
          Style="@(ShowPaper ? "padding: 24px;" : "padding: 0; background: transparent; box-shadow: none;")">
    @if (ShowTitle)
    {
        <MudText Typo="Typo.h6" GutterBottom="true">Neue Maßnahme erstellen</MudText>
    }

    <EditForm Model="@Model" OnValidSubmit="@HandleSubmit">
        <DataAnnotationsValidator />

        <MudGrid>
            <MudItem xs="12" md="3">
                <MudTextField @bind-Value="Model.IsoId"
                              Label="ISO-ID"
                              Variant="Variant.Outlined"
                              FullWidth="true"
                              Margin="Margin.Dense"
                              Placeholder="z.B. A.8.1.1"
                              For="@(() => Model.IsoId)" />
            </MudItem>

            <MudItem xs="12" md="3">
                <MudTextField @bind-Value="Model.Category"
                              Label="Kategorie"
                              Variant="Variant.Outlined"
                              FullWidth="true"
                              Margin="Margin.Dense"
                              Placeholder="z.B. Zugangskontrolle"
                              For="@(() => Model.Category)" />
            </MudItem>

            <MudItem xs="12" md="6">
                <MudTextField @bind-Value="Model.Name"
                              Label="Name der Maßnahme"
                              Variant="Variant.Outlined"
                              FullWidth="true"
                              Margin="Margin.Dense"
                              Placeholder="z.B. Passwortrichtlinie einführen"
                              For="@(() => Model.Name)" />
            </MudItem>

            <MudItem xs="12" md="2">
                <MudNumericField @bind-Value="Model.CostEur"
                                 Label="Kosten (EUR)"
                                 Variant="Variant.Outlined"
                                 Margin="Margin.Dense"
                                 Min="0"
                                 For="@(() => Model.CostEur)" />
            </MudItem>

            <MudItem xs="12" md="2">
                <MudNumericField @bind-Value="Model.EffortHours"
                                 Label="Aufwand (h)"
                                 Variant="Variant.Outlined"
                                 Margin="Margin.Dense"
                                 Min="0"
                                 For="@(() => Model.EffortHours)" />
            </MudItem>

            <MudItem xs="12" md="2">
                <MudSelect @bind-Value="Model.ImpactRisk"
                           Label="Risikowirkung (1–5)"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           For="@(() => Model.ImpactRisk)">
                    <MudSelectItem Value="1">1 – Sehr gering</MudSelectItem>
                    <MudSelectItem Value="2">2 – Gering</MudSelectItem>
                    <MudSelectItem Value="3">3 – Mittel</MudSelectItem>
                    <MudSelectItem Value="4">4 – Hoch</MudSelectItem>
                    <MudSelectItem Value="5">5 – Sehr hoch</MudSelectItem>
                </MudSelect>
            </MudItem>

            <MudItem xs="12" md="2">
                <MudSelect @bind-Value="Model.Confidence"
                           Label="Konfidenz (1–3)"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           For="@(() => Model.Confidence)">
                    <MudSelectItem Value="1">1 – Niedrig</MudSelectItem>
                    <MudSelectItem Value="2">2 – Mittel</MudSelectItem>
                    <MudSelectItem Value="3">3 – Hoch</MudSelectItem>
                </MudSelect>
            </MudItem>

            @if (ShowSubmitButton)
            {
            <MudItem xs="12" md="4">
                <MudButton ButtonType="ButtonType.Submit"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           Size="Size.Large"
                           FullWidth="true"
                           Disabled="@(Loading || string.IsNullOrWhiteSpace(Model.Name) || string.IsNullOrWhiteSpace(Model.IsoId))">
                    @if (Loading)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    }
                    Erstellen
                </MudButton>
            </MudItem>
            }

            <MudItem xs="12">
                <MudTextField @bind-Value="Model.Justification"
                              Label="Begründung (optional)"
                              Variant="Variant.Outlined"
                              Lines="2"
                              FullWidth="true"
                              Margin="Margin.Dense"
                              For="@(() => Model.Justification)" />
            </MudItem>

            @if ((AvailableCategories?.Count ?? 0) > 0 || (AvailableTags?.Count ?? 0) > 0)
            {
                <MudItem xs="12" md="6">
                    <TaxonomyPicker TItem="CategoryViewModel"
                                    Label="Kategorien"
                                    AvailableItems="@AvailableCategories"
                                    SelectedIds="@Model.SelectedCategoryIds"
                                    SelectedIdsChanged="@StateHasChanged"
                                    OnCreateRequested="@OnCreateCategoryRequested"
                                    GetId="@(x => x.Id)"
                                    GetLabel="@(x => x.Label)"
                                    GetColor="@(x => x.Color)" />
                </MudItem>
                <MudItem xs="12" md="6">
                    <TaxonomyPicker TItem="TagViewModel"
                                    Label="Tags"
                                    AvailableItems="@AvailableTags"
                                    SelectedIds="@Model.SelectedTagIds"
                                    SelectedIdsChanged="@StateHasChanged"
                                    OnCreateRequested="@OnCreateTagRequested"
                                    GetId="@(x => x.Id)"
                                    GetLabel="@(x => x.Label)"
                                    GetColor="@(x => x.Color)" />
                </MudItem>
            }
        </MudGrid>
    </EditForm>
</MudPaper>

@code {
    [Parameter, EditorRequired] public CreateMeasureViewModel            Model                     { get; set; } = default!;
    [Parameter, EditorRequired] public EventCallback                     OnSubmit                  { get; set; }
    [Parameter]                 public bool                              Loading                   { get; set; }
    [Parameter]                 public IReadOnlyList<CategoryViewModel>? AvailableCategories       { get; set; }
    [Parameter]                 public IReadOnlyList<TagViewModel>?      AvailableTags             { get; set; }
    [Parameter]                 public EventCallback<string>             OnCreateCategoryRequested { get; set; }
    [Parameter]                 public EventCallback<string>             OnCreateTagRequested      { get; set; }

    /// <summary>Blendet den "Erstellen"-Button aus — z.B. wenn das Formular in einem EntityDialog verwendet wird.</summary>
    [Parameter]                 public bool                              ShowSubmitButton          { get; set; } = true;
    /// <summary>Blendet die Überschrift "Neue Maßnahme erstellen" aus.</summary>
    [Parameter]                 public bool                              ShowTitle                 { get; set; } = true;
    /// <summary>Blendet das umgebende MudPaper aus — z.B. im Dialog-Modus.</summary>
    [Parameter]                 public bool                              ShowPaper                 { get; set; } = true;

    private async Task HandleSubmit() => await OnSubmit.InvokeAsync();
}
