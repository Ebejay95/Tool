{
  "ConnectionStrings": {
    "DefaultConnection": "Host=127.0.0.1;Port=5432;Database=cmc_local;Username=cmc_user;Password=local_dev_password_change_me"
  },
  "Jwt": {
    "SecretKey": "development-key-that-is-at-least-32-characters-long-for-jwt-signing",
    "Issuer": "Api.Development",
    "Audience": "Client.Development"
  },
  "Totp": {
    "Issuer": "CMC Dev"
  },
  "ApiSettings": {
    "BaseUrl": "http://localhost:8080",
    "FrontendBaseUrl": "http://localhost:8080"
  },
  "Email": {
    "Provider": "smtp",
    "Smtp": {
      "SmtpHost": "localhost",
      "SmtpPort": 1025,
      "UseSsl": false,
      "FromAddress": "noreply@cmc-local.dev",
      "FromName": "CMC Dev",
      "SimulateOnly": false
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft.AspNetCore": "Information",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System.Net.Http": "Information"
      }
    }
  },
  "Redis": {
    "ConnectionString": "localhost:6379,password=local_redis_password"
  },
  "Seq": {
    "ServerUrl": "http://localhost:5341"
  },
  "OpenTelemetry": {
    "OtlpEndpoint": "http://localhost:5341/ingest/otlp/v1/traces"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information"
    }
  }
}
